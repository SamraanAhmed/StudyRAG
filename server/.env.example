# OpenRouter API key — get yours at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Alternatively, you can name it:
# OperRouterAPI_KEY=your_openrouter_api_key_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://rag-chatbot.vercel.app
ALLOWED_ORIGIN=http://localhost:5173
